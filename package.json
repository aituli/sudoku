{
  "name": "shudu",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run test",
    "deploy": "bash deploy.sh",
    "zip": "npm run build && cd dist && zip -r ../shudu.zip . && cd .. && echo '✅ 已打包为 shudu.zip'"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "eslint": "^8.57.1",
    "typescript": "^6.0.3",
    "vite": "^5.4.21",
    "vitest": "^1.6.1"
  }
}
